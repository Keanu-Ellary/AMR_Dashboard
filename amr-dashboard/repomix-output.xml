              <span>Login</span>
            </Link>
          )}
          {isLoggedIn && (
            <button
              onClick={async () => { 
                await logout();
                window.location.href = "/home";
              }}
              className="flex items-center gap-3 px-3 py-2 text-sm text-sidebar-foreground hover:text-risk-high transition-colors font-medium w-full text-left"
            > 
              <LogOutIcon size={18} />
              <span>Logout</span>
            </button>
          )}
      </div>
    </div>
  );
}
