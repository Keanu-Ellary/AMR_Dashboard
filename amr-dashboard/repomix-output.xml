                  Add Images
                </a>
              </div>
              <div className="mt-4 text-sm text-gray-700 space-y-1">
                <p><strong>GPS Coordinates:</strong> {siteData.latitude.toFixed(5)}° S, {siteData.longitude.toFixed(5)}° E</p>
                <p><strong>Zone:</strong> {siteData.dangerZone || "Unknown"}</p>
